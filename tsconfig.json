{
    "compilerOptions": {
        /* project directories */
        "rootDir": "./",
        "outDir": "./dist",
        /* added types from @types */
        "types": ["bun"],
        /* Bundler mode */
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "moduleDetection": "force",
        /* transpilation settings */
        "module": "esnext",
        "target": "esnext",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "declaration": true,
        "sourceMap": true,
        "declarationMap": true,
        "noEmit": true,
        /* Linting */
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "allowUnusedLabels": false,
        "noUncheckedSideEffectImports": true,
        "noFallthroughCasesInSwitch": true,
        "allowUnreachableCode": false,
        "noUncheckedIndexedAccess": true,
        "noPropertyAccessFromIndexSignature": true,
        "erasableSyntaxOnly": true, // avoids using types such as `enum` that cannot be safely removed from the code without breaking it
        "noImplicitOverride": true,
        "noErrorTruncation": false,
        "exactOptionalPropertyTypes": false,
        "allowJs": true,
        "checkJs": false, // for each file to be checked, add `// @ts-check` as the first line
        /* JSX/TSX Syntax */
        "jsx": "react-jsx",
        "jsxImportSource": "hono/jsx",
        /* path definitions */
        "paths": {
            "@/*": ["./*"],
            "@src/*": ["./src/*"],
            "@lib/*": ["./src/lib/*"],
            "@middleware/*": ["./src/middleware/*"],
            "@routes/*": ["./src/routes/*"]
        }
    },
    /** source files */
    "file": ["./src/index.ts", "./hono.docs.ts"],
    "include": ["**/*.ts", "**/*.tsx"],
    "exclude": ["src/**/*.test.*", "test/", "dist/"]
}
