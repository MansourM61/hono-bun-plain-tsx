{
    "compilerOptions": {
        /* project directories */
        "rootDir": "./src",
        "outDir": "./dist",
        /* added types from @types */
        "types": ["bun"],
        /* transpilation settings */
        "module": "esnext",
        "moduleResolution": "bundler",
        "target": "esnext",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "allowJs": true,
        "resolveJsonModule": true,
        "moduleDetection": "force",
        "isolatedModules": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,
        "declaration": true,
        "sourceMap": true,
        "declarationMap": true,
        /* JSX/TSX Syntax */
        "jsx": "react-jsx",
        "jsxImportSource": "hono/jsx",
        /* path definitions */
        "paths": {
            "@/*": ["./*"],
            "@src/*": ["./src/*"],
            "@lib/*": ["./src/lib/*"],
            "@middleware/*": ["./src/middleware/*"],
            "@routes/*": ["./src/routes/*"]
        }
    },
    /** source files */
    "file": ["./src/index.ts"],
    "include": ["./src/**/*.ts"],
    "exclude": ["src/**/*.test.*"]
}
